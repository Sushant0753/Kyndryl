ENVIRONMENT=LOCAL

# Qdrant Settings (Qdrant Cloud)
QDRANT_HOST_URL=your_qdrant_host_url
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION_NAME=your_collection_name

# MongoDB Settings (Azure Cosmos DB or MongoDB)
DOCUMENT_DB_CONNECTION_STRING=your_mongodb_connection_string

# Azure OpenAI Embeddings
AZURE_OPENAI_ENDPOINT=your_azure_openai_endpoint
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5.1
AZURE_OPENAI_API_VERSION=2024-02-01

# Azure Storage
AZURE_STORAGE_CONNECTION_STRING=your_azure_storage_connection_string
AZURE_STORAGE_ACCOUNT_NAME=your_storage_account_name
AZURE_STORAGE_ACCOUNT_KEY=your_storage_account_key
AZURE_CONTAINER_NAME=your_container_name
AZURE_DATA_STORAGE=your_data_storage_name
RUN_TESTS=false

# Azure OpenAI GPT Endpoint (separate if using different resource)
AZURE_OPENAI_GPT_ENDPOINT=your_gpt_endpoint
AZURE_OPENAI_GPT_API_VERSION=2025-04-01-preview
AZURE_OPENAI_GPT_API_KEY=your_gpt_api_key
AZURE_OPENAI_GPT_DEPLOYMENT=gpt-5.1

# ElevenLabs TTS (Text-to-Speech)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_preferred_voice_id
